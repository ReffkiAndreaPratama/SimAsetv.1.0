@startuml ClassDiagram_SimAset
' ============================================================
' CLASS DIAGRAM — SimAset RBTV Bengkulu
' Berdasarkan kode aktual: Models, Controllers, Middleware,
' Helpers, Mail, Exports, Imports
' ============================================================

skinparam classBorderColor #2c3e50
skinparam classFontSize 10
skinparam classHeaderBackgroundColor #1a3470
skinparam classHeaderFontColor white
skinparam classBackgroundColor #f8f9fa
skinparam ArrowColor #2c3e50
skinparam ArrowThickness 1.5
skinparam packageBorderColor #1a3470
skinparam packageBackgroundColor #e8eaf6
skinparam packageFontColor #1a3470
skinparam noteBorderColor #f9a825
skinparam noteBackgroundColor #fffde7

title <b>Class Diagram</b>\nSimAset RBTV Bengkulu

' ============================================================
' MODELS (Eloquent ORM)
' ============================================================
package "Models (Eloquent ORM)" #dce8f5 {

  class User <<Model>> {
    + id : int <<PK, AUTO_INCREMENT>>
    + name : string
    + email : string <<UNIQUE>>
    # password : string <<bcrypt>>
    + role : string <<'admin'|'staff'>>
    + is_active : bool <<DEFAULT true>>
    + last_login_at : datetime
    + created_at : datetime
    + updated_at : datetime
    --
    + isAdmin() : bool
    + isStaff() : bool
    + getAvatarDefault() : string
    + sendPasswordResetNotification(token) : void
    --
    # table = 'users'
    # fillable : array
    # hidden : array
    # casts : array
    <<HasFactory, Notifiable>>
  }

  class Asset <<Model>> {
    + kode_aset : string <<PK, Format: AST-001>>
    + kode_barang : string <<FK>>
    + ruangan_id : int <<FK, NULL>>
    + kondisi : string <<Baik|Rusak Ringan|Rusak Berat>>
    + status : string <<Aktif|Maintenance|Non-Aktif>>
    + serial_number : string <<NULL>>
    + foto : string <<NULL>>
    + jumlah : int <<DEFAULT 1>>
    + tanggal_perolehan : date <<NULL>>
    + harga_perolehan : decimal(15,2) <<NULL>>
    + sumber_perolehan : string <<NULL>>
    + keterangan : string <<NULL>>
    + created_by : int <<NULL>>
    + updated_by : int <<NULL>>
    + created_at : datetime
    + updated_at : datetime
    + deleted_at : datetime <<NULL>>
    --
    + barang() : BelongsTo
    + ruangan() : BelongsTo
    + creator() : BelongsTo
    + updater() : BelongsTo
    + getNamaBarangAttribute() : string
    + getKategoriAttribute() : string
    + getNamaRuanganAttribute() : string
    + {static} generateKode() : string
    --
    # table = 'aset'
    # primaryKey = 'kode_aset'
    # incrementing = false
    # fillable : array
    # casts : array
    <<SoftDeletes>>
  }

  class Barang <<Model>> {
    + kode_barang : string <<PK, Format: BRG-001>>
    + nama_barang : string
    + kategori : string <<Kamera|Audio|Komputer|...>>
    + status : string <<aktif|nonaktif>>
    + keterangan : string <<NULL>>
    + created_at : datetime
    + updated_at : datetime
    + deleted_at : datetime <<NULL>>
    --
    + aset() : HasMany
    + {static} generateKode() : string
    --
    # table = 'barang'
    # primaryKey = 'kode_barang'
    # incrementing = false
    # fillable : array
    <<SoftDeletes>>
  }

  class Ruangan <<Model>> {
    + id : int <<PK, AUTO_INCREMENT>>
    + nama : string
    + lantai : string <<NULL>>
    + keterangan : string <<NULL>>
    + created_at : datetime
    --
    + assets() : HasMany
    + getNamaRuanganAttribute() : string
    --
    # table = 'ruangan'
    # fillable : array
  }

  class ActivityLog <<Model>> {
    + id : bigint <<PK, AUTO_INCREMENT>>
    + user_id : bigint <<NULL>>
    + aktivitas : string <<Login|Logout|Create|Update|Delete>>
    + keterangan : string <<NULL>>
    + ip_address : string <<NULL>>
    + user_agent : string <<NULL>>
    + created_at : datetime
    + updated_at : datetime
    --
    + user() : BelongsTo
    --
    # table = 'log_aktivitas'
    # fillable : array
  }

}

