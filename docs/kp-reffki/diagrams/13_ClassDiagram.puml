' ============================================================
' MIDDLEWARE
' ============================================================
package "Middleware" #f5d5d5 {

  class RoleMiddleware <<Middleware>> {
    + handle(Request, Closure, ...roles) : Response
    --
    ' Cek: Auth::user()->role in $roles
    ' Jika tidak: abort(403)
  }

  class LogActivity <<Middleware>> {
    + handle(Request, Closure) : Response
    + terminate(Request, Response) : void
    --
    ' terminate() mencatat aktivitas
    ' berdasarkan method + path:
    ' POST /login → Login
    ' POST /logout → Logout
    ' POST /aset → Create
    ' PUT /aset/{id} → Update
    ' DELETE /aset/{id} → Delete
    ' (juga untuk barang & ruangan)
  }

  class SecurityHeaders <<Middleware>> {
    + handle(Request, Closure) : Response
    --
    ' Set headers:
    ' X-Content-Type-Options: nosniff
    ' X-Frame-Options: DENY
    ' X-XSS-Protection: 1; mode=block
    ' Referrer-Policy: strict-origin-when-cross-origin
    ' Content-Security-Policy: frame-ancestors 'self'
  }

}

' ============================================================
' HELPERS
' ============================================================
package "Helpers" #e8d5f5 {

  class ActivityLogger <<Helper>> {
    + {static} log(aktivitas, keterangan) : ActivityLog
    + {static} logAuth(aktivitas, keterangan) : ActivityLog
    + {static} logAsset(aktivitas, keterangan, asset) : ActivityLog
    + {static} logMutasi(aktivitas, keterangan, asset) : ActivityLog
    + {static} logUser(aktivitas, keterangan, user) : ActivityLog
    --
    ' Semua method memanggil log()
    ' Menyimpan: user_id, aktivitas,
    ' keterangan, ip_address, user_agent
  }

  class ImageHelper <<Helper>> {
    + {static} resize(file, width, height) : string
    + {static} delete(filename) : bool
  }

}

' ============================================================
' MAIL
' ============================================================
package "Mail (Mailable)" #fff3cd {

  class AkunBaruMail <<Mailable>> {
    + user : User
    + plainPassword : string
    --
    + __construct(user, plainPassword)
    + envelope() : Envelope
    + content() : Content
    --
    ' Dikirim saat Admin tambah
    ' pengguna baru dengan opsi
    ' "Kirim Email" dicentang
  }

  class MaintenanceAlert <<Mailable>> {
    + asset : Asset
    + type : string <<'selesai'>>
    --
    + __construct(asset, type)
    + envelope() : Envelope
    + content() : Content
    --
    ' Dikirim ke semua Admin aktif
    ' saat maintenance selesai
  }

}

' ============================================================
' EXPORTS & IMPORTS
' ============================================================
package "Exports & Imports" #d5f5e3 {

  class AssetExportFile <<Export>> {
    + filters : array
    --
    + __construct(filters)
    + query() : Builder
    + headings() : array
    + map(row) : array
    --
    ' Implements: FromQuery,
    ' WithHeadings, WithMapping
  }

  class BarangExportFile <<Export>> {
    + query() : Builder
    + headings() : array
    --
    ' Implements: FromQuery,
    ' WithHeadings
  }

  class AssetImport <<Import>> {
    + model(row) : Asset
    + rules() : array
    --
    ' Implements: ToModel,
    ' WithValidation
  }

}

' ============================================================
' NOTIFICATIONS
' ============================================================
package "Notifications" #fce4ec {

  class ResetPasswordNotification <<Notification>> {
    + token : string
    --
    + __construct(token)
    + toMail(notifiable) : MailMessage
    --
    ' Mengirim link reset password
    ' ke email pengguna
  }

}

' ============================================================
' RELASI ANTAR CLASS
' ============================================================

' ── Model Relationships ──
User "1" o-- "0..*" Asset : created_by / updated_by
User "1" o-- "0..*" ActivityLog : user_id
Barang "1" *-- "0..*" Asset : kode_barang\n(RESTRICT del)
Ruangan "1" o-- "0..*" Asset : ruangan_id\n(SET NULL del)

' ── Controller → Model ──
AssetController ..> Asset : uses
AssetController ..> Barang : uses
AssetController ..> Ruangan : uses
AssetController ..> ActivityLogger : uses

BarangController ..> Barang : uses
RuanganController ..> Ruangan : uses
RuanganController ..> Asset : uses

MaintenanceController ..> Asset : uses
MaintenanceController ..> User : uses
MaintenanceController ..> ActivityLogger : uses
MaintenanceController ..> MaintenanceAlert : creates

UserController ..> User : uses
UserController ..> AkunBaruMail : creates

AuditLogController ..> ActivityLog : uses

DashboardController ..> Asset : uses
DashboardController ..> Barang : uses
DashboardController ..> Ruangan : uses

LaporanController ..> Asset : uses
LaporanController ..> Ruangan : uses

ExportController ..> AssetExportFile : creates
ExportController ..> BarangExportFile : creates

ImportController ..> AssetImport : creates

' ── Middleware → Helper ──
LogActivity ..> ActivityLogger : uses

' ── Auth ──
AuthenticatedSessionController ..> ActivityLogger : uses
User ..> ResetPasswordNotification : sends

@enduml
