@startuml Activity_ImportExport_SimAset
' ============================================================
' ACTIVITY DIAGRAM — Import Data (Excel/CSV)
' SimAset RBTV Bengkulu
' ============================================================

skinparam activityBorderColor #2c3e50
skinparam activityBackgroundColor #fffde7
skinparam activityFontSize 11
skinparam activityArrowColor #2c3e50
skinparam activityArrowThickness 1.5
skinparam swimlaneBorderColor #1a3470
skinparam partitionBorderColor #1a3470
skinparam partitionBackgroundColor #e8eaf6
skinparam noteBorderColor #f9a825
skinparam noteBackgroundColor #fffde7

title <b>Activity Diagram — Import Data (Excel/CSV)</b>\nSimAset RBTV Bengkulu

|Pengguna|
start

:Login ke sistem;

:Pilih menu "Import"\ndari halaman Aset atau Barang;

|Sistem|
:Tampilkan halaman import\ndengan pilihan tipe (Aset/Barang)\ndan tombol download template;

|Pengguna|
if (Perlu template?) then (Ya)
  :Klik "Download Template";

  |Sistem|
  :GET /import/template;
  :Generate file Excel template\ndengan header kolom yang benar;
  :Download file template.xlsx;

  |Pengguna|
  :Isi data di template Excel;
else (Tidak)
endif

:Pilih tipe import:\n(Aset atau Barang);

:Upload file Excel/CSV;

:Klik "Import";

|Sistem|
:POST /import\n{file, type};

:Validasi file:\n- required\n- mimes: xlsx, xls, csv\n- type: in:aset,barang;

if (Validasi file\ngagal?) then (Ya)
  :Tampilkan pesan error\n"File harus berformat Excel atau CSV";
  |Pengguna|
  :Pilih file yang benar;
  |Sistem|
else (Tidak)
endif

if (Tipe = 'aset'?) then (Ya)
  :Excel::import(\n  new AssetImport(),\n  $request->file('file')\n);

  :Untuk setiap baris data:;

  fork
    :Validasi baris:\n- kode_barang exists di barang\n- ruangan_id exists di ruangan\n- kondisi valid\n- status valid;

    if (Validasi baris\ngagal?) then (Ya)
      :Skip baris ini\n(catat error);
    else (Tidak)
      :Asset::create($row)\ndengan kode_aset auto-generate;
    endif

  fork again
    note right
      Proses dilakukan
      per baris secara
      berurutan
    end note
  end fork

else (Tipe = 'barang')
  :Excel::import(\n  new BarangImport(),\n  $request->file('file')\n);

  :Untuk setiap baris data:;

  :Validasi dan simpan\ndata barang;
endif

:Hitung jumlah:\n- Berhasil diimport\n- Gagal/dilewati;

:Redirect ke halaman aset/barang\ndengan flash message:\n"Import selesai: X data berhasil,\nY data gagal";

|Pengguna|
:Melihat hasil import\ndi daftar data;

stop

@enduml
