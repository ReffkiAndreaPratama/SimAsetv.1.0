        <mxCell id="als2" value="ActivityLog::with(&#39;user&#39;)-&gt;orderBy(&#39;created_at&#39;,&#39;desc&#39;)-&gt;paginate(20)&#xa;Tampilkan tabel log (id, user, aktivitas, keterangan, ip, waktu)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="sw_s"><mxGeometry x="40" y="230" width="520" height="60" as="geometry"/></mxCell>
