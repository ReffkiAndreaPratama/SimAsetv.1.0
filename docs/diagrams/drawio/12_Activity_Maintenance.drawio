        <mxCell id="msec1" value="BAGIAN 1: Set Aset ke Maintenance" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;spacingLeft=4;spacingRight=4;overflow=hidden;rotatable=0;fontSize=11;fontStyle=1;" vertex="1" parent="sw_u"><mxGeometry x="10" y="150" width="290" height="30" as="geometry"/></mxCell>
