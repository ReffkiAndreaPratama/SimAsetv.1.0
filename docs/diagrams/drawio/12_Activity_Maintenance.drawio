        <mxCell id="ms1" value="Tampilkan modal konfirmasi + input keterangan (opsional)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="sw_s"><mxGeometry x="30" y="200" width="440" height="40" as="geometry"/></mxCell>
