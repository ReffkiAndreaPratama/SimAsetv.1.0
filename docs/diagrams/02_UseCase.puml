' ============================================================
' RELASI INCLUDE & EXTEND
' ============================================================
' ATURAN:
'   <<include>> = use case BASE selalu memanggil use case ini
'   <<extend>>  = use case ini memperluas BASE hanya jika kondisi terpenuhi
'                 Arah panah: dari extending UC ke base UC

' ── Autentikasi ──
' Lupa Password memerlukan Reset Password sebagai langkah lanjutan
' (user klik link di email → halaman reset password)
UC_ResetPwd ..> UC_LupaPassword : <<extend>>

' ── Manajemen Aset ──
' Upload foto adalah opsional saat tambah/edit aset
UC_TambahAset ..> UC_UploadFoto : <<extend>>
UC_EditAset ..> UC_UploadFoto : <<extend>>

' Hapus massal adalah perluasan dari lihat daftar (kondisi: ada yang dicentang)
UC_BatchHapus ..> UC_ListAset : <<extend>>

' ── QR Code ──
' Scan QR selalu menampilkan detail aset
UC_ScanQR ..> UC_DetailQR : <<include>>

' Lihat QR adalah bagian dari generate QR (setelah generate, langsung tampil)
UC_GenQR ..> UC_LihatQR : <<extend>>

' Batch print adalah perluasan dari lihat daftar (kondisi: ada yang dicentang)
UC_BatchQR ..> UC_ListAset : <<extend>>

' ── Maintenance ──
' Selesaikan maintenance selalu mengirim email ke admin
UC_SelesaiMaint ..> UC_EmailAdmin : <<include>>

' ── Tambah Pengguna ──
' Kirim email akun baru adalah opsional (kondisi: checkbox dicentang)
UC_TambahUser ..> UC_KirimEmailAkun : <<extend>>

' ── Laporan ──
' Cetak PDF dan Export Excel adalah perluasan dari laporan aset
UC_CetakAset ..> UC_LapAset : <<extend>>
UC_ExportLapAset ..> UC_LapAset : <<extend>>

' Filter audit log adalah perluasan dari lihat audit log
UC_FilterAudit ..> UC_AuditLog : <<extend>>

' ── Use case yang di-include tapi tidak punya aktor langsung ──
' (didefinisikan di luar system boundary sebagai use case abstrak)
usecase "Kirim Email\nNotifikasi Admin\n(Maintenance Selesai)" as UC_EmailAdmin
usecase "Kirim Email\nAkun Baru" as UC_KirimEmailAkun

@enduml
