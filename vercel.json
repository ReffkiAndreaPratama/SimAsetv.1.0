{
  "functions": {
    "api/index.php": {
      "runtime": "vercel-php@0.7.3"
    }
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/api/index.php"
    }
  ]
}{
  "outputDirectory": "public/build",
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/public/index.php"
    }
  ]
}
